{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "snapshot": true,
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "share": "manual",
  "permission": {
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git remote *": "allow",
      "git tag *": "allow",
      "git blame *": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git describe *": "allow",
      "git stash list *": "allow",
      "git stash show *": "allow",
      "git reflog *": "allow",
      "git fetch *": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "kubectl api-resources *": "allow",
      "kubectl api-versions": "allow",
      "kubectl explain *": "allow",
      "kubectl cluster-info *": "allow",
      "kubectl version": "allow",
      "kubectl config *": "allow",
      "kubectl diff *": "allow",
      "kubectl auth can-i *": "allow",
      "kubectl events *": "allow",
      "kubectl wait *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "df *": "allow",
      "du *": "allow",
      "ps *": "allow",
      "free *": "allow",
      "whoami": "allow",
      "id": "allow",
      "date": "allow",
      "uname *": "allow",
      "uptime": "allow",
      "printenv *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "hostname": "allow",
      "type *": "allow",
      "ip *": "allow",
      "ss *": "allow",
      "dmesg *": "allow",
      "history": "allow",
      "lscpu": "allow",
      "lsblk *": "allow",
      "lspci *": "allow",
      "lsusb *": "allow",
      "journalctl *": "allow",
      "systemctl list-*": "allow",
      "systemctl show *": "allow",
      "systemctl is-*": "allow",
      "systemctl status *": "allow",
      "systemctl cat *": "allow",
      "echo *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "readlink *": "allow",
      "realpath *": "allow"
    },
    "write": "ask"
  }
}
