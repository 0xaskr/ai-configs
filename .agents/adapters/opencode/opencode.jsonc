{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "snapshot": true,
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "share": "manual",
  "permission": {
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git remote *": "allow",
      "git tag *": "allow",
      "git blame *": "allow",
      "git rev-parse *": "allow",
      "git rev-list *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git describe *": "allow",
      "git stash list *": "allow",
      "git stash show *": "allow",
      "git reflog *": "allow",
      "git fetch *": "allow"
    },
    "write": "ask"
  }
}
