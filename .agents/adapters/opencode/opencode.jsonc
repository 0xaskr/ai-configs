{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "snapshot": true,
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "share": "manual",
  "permission": {
    "bash": "ask",
    "write": "ask"
  }
}
